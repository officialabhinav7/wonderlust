<% layout("layouts/boilerplate") %>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5">
  <div class="card shadow-lg p-4">

    <!-- Image -->
    <img 
      src="<%= listing1.image?.url || listing1.image %>" 
      class="card-img-top mb-4" 
      style="max-height:400px; object-fit:cover; border-radius:10px;"
    >

    <!-- Title -->
    <h2 class="mb-3"><%= listing1.title %></h2>

    <!-- Price -->
    <h4 class="text-success mb-3">₹ <%= listing1.price %></h4>

    <!-- Description -->
    <p class="mb-3"><%= listing1.description %></p>

    <!-- Location -->
    <p class="text-muted">
      📍 <%= listing1.location %>, <%= listing1.country %>
    </p>

    <!-- Buttons -->
   

      <!-- Edit -->
      <form action="/listings/<%= listing1._id %>/edit" method="get">
        <button class="btn btn-warning">Edit</button>
      </form>
   <br> 
      <!-- Delete -->
      <form method="post" action="/listings/<%= listing1._id %>?_method=delete">
        
        <button class="btn btn-danger">Delete</button>
      </form>
      <br>
     <h3 class="mt-5">Add Review</h3>

<form action="/listings/<%= listing1._id %>/reviews" method="POST" class="d-flex flex-column gap-3 mt-3">

  <div>
    <label class="form-label">Rating:</label>
    <input 
      type="number" 
      name="review[rating]" 
      min="1" 
      max="5" 
      required 
      class="form-control"
    >
  </div>

  <div>
    <label class="form-label">Comment:</label>
    <textarea 
      name="review[comment]" 
      required 
      class="form-control"
    ></textarea>
  </div>

  <button type="submit" class="btn btn-primary">Submit</button>

</form>
   <h2 class="mt-5 mb-4">Reviews</h2>
   <div class="row">
     <% for(let review of listing1.reviews){ %>
       <div class="col-md-6 mb-3">
         <div class="card h-100 shadow-sm">
           <div class="card-body">
             <div class="d-flex justify-content-between align-items-start">

               <div>
                 <h6 class="card-subtitle mb-2 text-muted"><%= review.author || "Anonymous" %></h6>
                 <div class="mb-2">
                   <% for(let i = 0; i < review.rating; i++){ %>
                     ⭐
                   <% } %>
                 </div>
               </div>
               <small class="text-muted"><%= new Date(review.createdAt).toLocaleDateString() %></small>
             </div>
             <p class="card-text"><%= review.comment %></p>
           </div>
            <form action="/listings/<%= listing1._id %>/reviews/<%= review._id %>?_method=delete" method="POST">
                  <button>delete</button>
            </form>
         </div>
        
       </div>
       

     <% } %>
   </div>

   

  </div>
</div>