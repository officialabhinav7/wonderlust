<% layout("layouts/boilerplate") %>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5">
  <div class="card p-4 shadow">
    <h3>Add Listing</h3>

    <form method="post" action="/listings">
      
      <input class="form-control mb-3" type="text" name="listing[title]" placeholder="Enter title"  required>

      <textarea class="form-control mb-3" name="listing[description]" placeholder="Enter description" required></textarea>

      <input class="form-control mb-3" name="listing[image]" placeholder="Enter image URL">

      <input class="form-control mb-3" name="listing[price]" placeholder="Enter price" required>

      <input class="form-control mb-3" name="listing[location]" placeholder="Enter location" required>

      <input class="form-control mb-3" type="text" name="listing[country]" placeholder="Enter country" required>

      <button class="btn btn-primary w-100">Add</button>

    </form>
  </div>
</div>