<% layout("layouts/boilerplate") %>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5">
  <div class="card shadow p-4">
    <h3 class="mb-4">Edit Listing</h3>

    <form action="/listings/<%= listing._id %>?_method=put" method="post">

      <label class="form-label">Title</label>
      <input class="form-control mb-3" type="text" name="listing[title]" value="<%= listing.title %>" required>

      <label class="form-label">Description</label>
      <textarea class="form-control mb-3" name="listing[description]" required><%= listing.description %></textarea>

      <label class="form-label">Image URL</label>
      <input class="form-control mb-2" id="imageInput" name="listing[image]" value="<%= listing.image %>">

      <!-- Image Preview -->
      <img id="preview" src="<%= listing.image %>" class="mb-3" style="max-width:200px; border-radius:10px;">

      <label class="form-label">Price</label>
      <input class="form-control mb-3" type="number" name="listing[price]" value="<%= listing.price %>" required>

      <label class="form-label">Location</label>
      <input class="form-control mb-3" name="listing[location]" value="<%= listing.location %>">

      <label class="form-label">Country</label>
      <input class="form-control mb-4" type="text" name="listing[country]" value="<%= listing.country %>">

      <button class="btn btn-success w-100">Update Listing</button>

    </form>
  </div>
</div>